@using MedAssistNG.Client.Models

<div class="triage-result-container">

    @if (Result?.Urgency?.ToUpper() == "RED")
    {
        <div class="critical-alert">
            🚨 CRITICAL TRIAGE ALERT — Immediate medical attention required
        </div>
    }

    <div class="triage-header-banner @(Result?.Urgency?.ToLower() ?? "")">
        <div class="urgency-indicator">
            <span class="status-dot"></span>
            <span>Triage Priority: @Result.Urgency</span>
        </div>
        <div class="timestamp">Generated: @ReportTime?.ToString("g")</div>
    </div>

    <div class="confidence-meter">
        <span>📊 Clinical Confidence</span>
        <div class="confidence-bar">
            <div class="confidence-fill" style="width:85%"></div>
        </div>
    </div>

    <div class="clinical-section">
        <h3>🧠 Clinical Reasoning</h3>
        <p>@Result.ClinicalReasoning</p>
    </div>

    @if (Result?.ProbableConditions?.Any() == true)
    {
        <div class="clinical-section">
            <h3>🧬 Probable Conditions</h3>
            <ul>
                @foreach (var c in Result.ProbableConditions)
                {
                    <li>@c</li>
                }
            </ul>
        </div>
    }

    <div class="clinical-section">
        <h3>⚡ Recommended Action</h3>
        <p>@Result.RecommendedAction</p>
    </div>

    @if (Result?.DangerSigns?.Any() == true)
    {
        <div class="clinical-section danger-signs">
            <h3>⚠️ Danger Signs to Monitor</h3>
            <ul>
                @foreach (var sign in Result.DangerSigns)
                {
                    <li>@sign</li>
                }
            </ul>
        </div>
    }

    <div class="safety-disclaimer">
        <span class="icon">ℹ️</span>
        <p><strong>AI-Assisted Triage Only.</strong> This output is generated by Gemini and does not replace professional medical diagnosis. Clinicians should verify all recommendations.</p>
    </div>

</div>

@code {
    [Parameter] public TriageResult Result { get; set; } = null!;
    [Parameter] public DateTime? ReportTime { get; set; }
}